# Copy to /etc/stemdeck/stemdeck.env and edit for your VPS.
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DATA_DIR=/var/lib/stemdeck
SESSION_DAYS=30
REUSE_PROCESSED_OUTPUTS=true
FAST_SEPARATOR_MODEL=UVR-MDX-NET-Voc_FT.onnx
FAST_SEPARATOR_MODEL_DIR=/var/cache/stemdeck/audio-separator
XDG_CACHE_HOME=/var/cache/stemdeck
TORCH_HOME=/var/cache/stemdeck/torch

# Queue. Install rabbitmq-server on the VPS, or point this to a remote broker.
CELERY_BROKER_URL=pyamqp://guest:guest@localhost//
CELERY_RESULT_BACKEND=rpc://

# Storage. Use "local" for the simplest VPS setup, or "minio" with stemdeck-minio.service.
STORAGE_BACKEND=local
STORAGE_ENDPOINT=127.0.0.1:9000
STORAGE_ACCESS_KEY=stemdeck
STORAGE_SECRET_KEY=change-this-secret
STORAGE_BUCKET=stemdeck
STORAGE_SECURE=false
